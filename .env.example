# --- Database (MongoDB) ---
# Easiest option: a free MongoDB Atlas cluster (cloud.mongodb.com).
# Create a cluster -> Database Access user -> Network Access "allow from anywhere"
# (0.0.0.0/0, fine for a hackathon demo) -> copy the connection string below.
# Must include a database name after the host, e.g. ".../resume_reviewer?..."
DATABASE_URL="mongodb+srv://dbss:opop@cluster0.ubw38y7.mongodb.net/resume_reviewer?retryWrites=true&w=majority&appName=Cluster0"

# --- NextAuth ---
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# --- AI provider (used to score resumes) ---
# Optional: if omitted, the app automatically falls back to a deterministic
# local heuristic scorer so the product still works end-to-end without a key.
ANTHROPIC_API_KEY=""

# --- Stripe (test mode) ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."   # Recurring monthly price created in Stripe Dashboard (test mode)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
